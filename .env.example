# ── Base de données ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleetview
DB_USER=fleetview
DB_PASSWORD=changeme_secure_password

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=changeme_very_long_random_string_256bits
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Webfleet API ─────────────────────────────────────────────
WEBFLEET_BASE_URL=https://csv.webfleet.com
WEBFLEET_ACCOUNT=votre_compte
WEBFLEET_USERNAME=votre_utilisateur
WEBFLEET_PASSWORD=votre_mot_de_passe
WEBFLEET_API_KEY=votre_cle_api

# ── Tankyou API ──────────────────────────────────────────────
TANKYOU_BASE_URL=https://api.tankyou.fr/v1
TANKYOU_API_KEY=votre_cle_api_tankyou

# ── Total Energies API ───────────────────────────────────────
TOTAL_BASE_URL=https://api.totalenergies.fr/fleet/v2
TOTAL_CLIENT_ID=votre_client_id
TOTAL_CLIENT_SECRET=votre_client_secret

# ── MTS-1 API ────────────────────────────────────────────────
# Token Bearer obtenu depuis console.mts-1.com (Settings > API)
MTS1_API_TOKEN=votre_token_bearer_mts1
# ID shipper ACARIS sur MTS-1
MTS1_SHIPPER_ID=63c854d713123429cd48ed43

# ── Application ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
